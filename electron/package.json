{
  "name": "fold-live-shell",
  "version": "0.1.0",
  "description": "Electron shell for Fold Live — loads the built Fold web app (../dist) and provides native host services (Syphon output) the browser can't. Wrapper only; the web app stays plain Vite + vanilla JS.",
  "main": "main.js",
  "type": "commonjs",
  "license": "AGPL-3.0-or-later",
  "author": "Daniel Nelson",
  "scripts": {
    "start": "electron .",
    "dist": "node scripts/build-dmg.cjs",
    "postinstall": "node scripts/patch-node-syphon.cjs"
  },
  "dependencies": {
    "node-syphon": "1.5.0"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "art.curiousimagery.fold-live",
    "productName": "Fold Live",
    "copyright": "Copyright © 2026 Daniel Nelson",
    "directories": { "output": "release" },
    "files": ["main.js", "preload.js", "syphon-bridge.js", "node_modules/**/*"],
    "extraResources": [{ "from": "../dist", "to": "dist" }],
    "asarUnpack": ["node_modules/node-syphon/**/*"],
    "npmRebuild": false,
    "mac": {
      "target": [{ "target": "dmg", "arch": "arm64" }],
      "identity": null,
      "icon": "build/icon.png",
      "category": "public.app-category.video",
      "extendInfo": {
        "NSCameraUsageDescription": "Fold uses the camera as a live kaleidoscope source."
      }
    }
  }
}
